# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
ALLOWED_USER_IDS=123456789,987654321

# Claude Code SDK
ANTHROPIC_API_KEY=your-anthropic-api-key

# GitHub — for cloning repos via /clone command
GITHUB_PAT=your-github-personal-access-token
GITHUB_OWNER=your-github-username

# Projects directory — repos are cloned here, auto-discovered
PROJECTS_DIR=/opt/projects

# Default project (optional — must match a directory name in PROJECTS_DIR)
DEFAULT_PROJECT=finito-divorce

# Optional: Health check server
PORT=3100
